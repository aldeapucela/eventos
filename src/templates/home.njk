{% extends "layout.njk" %}

{% block header %}
<header class="topbar">
  <div class="topbar-inner">
    <a class="header-brand home-brand-mobile flex items-center gap-4" href="/" aria-label="Aldea Pucela Eventos">
      <img src="https://aldeapucela.org/img/logo-web.jpg" alt="" class="home-brand-mobile-mark" />
      <span class="home-brand-mobile-copy">
        <span class="home-brand-mobile-kicker">ALDEA PUCELA</span>
        <span class="home-brand-mobile-title">Eventos</span>
      </span>
    </a>
    <nav class="header-main-nav hidden lg:flex" aria-label="Navegación principal">
      <a class="nav-link nav-link-active" href="/">
        <i class="fa-solid fa-house" aria-hidden="true"></i>
        <span>Inicio</span>
      </a>
      <a class="nav-link " href="/guardados">
        <i class="fa-regular fa-bookmark" aria-hidden="true"></i>
        <span>Mis guardados</span>
      </a>
      <a class="nav-link " href="/archivo">
        <i class="fa-solid fa-box-archive" aria-hidden="true"></i>
        <span>Archivo</span>
      </a>
      <button class="nav-link" type="button" data-subscribe-open>
        <i class="fa-solid fa-rss" aria-hidden="true"></i>
        <span>Suscribirse</span>
      </button>
      <a class="nav-link" href="https://aldeapucela.org" target="_blank" rel="noopener noreferrer">
        <i class="fa-solid fa-people-group" aria-hidden="true"></i>
        <span>Comunidad</span>
      </a>
      <a class="nav-link" href="https://t.me/aldeapucela/244" target="_blank" rel="noopener noreferrer">
        <i class="fa-brands fa-telegram" aria-hidden="true"></i>
        <span>Chat</span>
      </a>
      <button class="nav-link nav-theme-toggle" type="button" data-theme-toggle aria-label="Cambiar tema" aria-pressed="false">
        <i class="fa-regular fa-moon" aria-hidden="true"></i>
        <span data-theme-toggle-label>Modo oscuro</span>
      </button>
    </nav>
    <button class="header-search-btn inline-flex h-11 w-11 items-center justify-center rounded-full text-slate-500 lg:hidden" type="button" data-menu-open aria-label="Abrir menú">
      <i class="fa-solid fa-bars"></i>
    </button>
  </div>
</header>
{% endblock %}

{% block body %}
<main class="page-shell py-5 sm:py-8 lg:py-10">
  <section class="home-layout space-y-8 lg:space-y-10">
    <div class="home-column space-y-6">
      <section class="hero-mobile-copy">
        <div class="hero-mobile-visual">
          <img
            class="hero-mobile-image"
            src="/assets/home-hero.jpg"
            alt=""
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
          <div class="hero-mobile-overlay">
            <div class="hero-mobile-text-panel">
              <h1 class="hero-mobile-title">Qué hacer en Valladolid</h1>
              <p class="hero-mobile-subtitle">Agenda vecinal de eventos culturales</p>
              <span class="hero-mobile-accent" aria-hidden="true"></span>
            </div>
          </div>
        </div>

        <div class="hero-mobile-search hidden" aria-hidden="true">
          <i class="fa-solid fa-magnifying-glass"></i>
          <span>Buscar eventos, lugares, temas...</span>
        </div>

        <div class="mobile-chip-row" aria-label="Filtros rápidos">
          <button class="mobile-chip" data-filter="Hoy">
            <i class="mobile-chip-icon fa-regular fa-sun" aria-hidden="true"></i>
            <span>Hoy</span>
          </button>
          <button class="mobile-chip" data-filter="Este finde">
            <i class="mobile-chip-icon fa-solid fa-umbrella-beach" aria-hidden="true"></i>
            <span>Este finde</span>
          </button>
          <button class="mobile-chip" data-filter="Esta semana">
            <i class="mobile-chip-icon fa-regular fa-calendar" aria-hidden="true"></i>
            <span>Esta semana</span>
          </button>
          <button class="mobile-chip" data-filter="Próxima semana">
            <i class="mobile-chip-icon fa-solid fa-calendar-plus" aria-hidden="true"></i>
            <span>Próxima semana</span>
          </button>
          <button class="mobile-chip" data-filter="Este mes">
            <i class="mobile-chip-icon fa-regular fa-calendar-days" aria-hidden="true"></i>
            <span>Este mes</span>
          </button>
          <button class="mobile-chip" data-filter="free">
            <i class="mobile-chip-icon fa-solid fa-ticket" aria-hidden="true"></i>
            <span>Gratis</span>
          </button>
          <button class="mobile-chip mobile-chip-select-wrap" type="button" data-type-modal-open aria-label="Filtrar por tipo">
            <i class="mobile-chip-icon mobile-chip-leading fa-solid fa-filter" aria-hidden="true"></i>
            <span data-filter-type-label>Tipo</span>
          </button>
        </div>
      </section>

      {% if featured %}
      {% if featured %}
      <section class="space-y-4">
        <div class="section-mobile-head">
          <h2 class="section-mobile-title">Destacado</h2>
        </div>
        <article class="featured-mobile-card">
          <div class="featured-mobile-image" style="background-image:url('{{ featured.image }}')"></div>
          <div class="featured-mobile-copy">
            <p class="muted-label">{{ featured.categoryLabel or 'Destacado' }}</p>
            <h3 class="featured-mobile-title">{{ featured.title }}</h3>
            <p class="featured-mobile-summary">{{ featured.summary or featured.excerpt }}</p>
            <div class="featured-mobile-meta">
              <span>{% if featured.scheduleLabel %}{{ featured.scheduleLabel }}{% else %}{{ featured.dateRangeLabel }}{% endif %}</span>
              {% if featured.location %}<span>{{ featured.location }}</span>{% endif %}
            </div>
            {% if featured.isFree %}
            <span class="compact-badge compact-badge-success">Entrada libre</span>
            {% endif %}
          </div>
        </article>
      </section>
      {% endif %}
      {% endif %}

      <section class="space-y-3">
        <div class="section-mobile-head">
          <h2 class="section-mobile-title" data-results-title>Próximos 30 días</h2>
          <a class="section-mobile-link hidden" href="/" data-clear-filters>Ver todo</a>
        </div>
        <div class="week-groups" id="week-groups" data-week-groups></div>
        <p class="hidden text-sm leading-6 text-slate-500" data-week-empty>No hay eventos para este filtro.</p>
        <div class="event-row-list" id="event-grid" hidden>
          {% for event in week %}
          <article class="event-compact event-compact-featured" data-category="{{ event.categoryLabel }}" data-free="{{ 'true' if event.isFree else 'false' }}" data-starts-at="{{ event.startsAt }}">
            <a href="{{ event.urlPath }}" class="event-compact-link">
              <div class="event-compact-image" style="background-image:url('{{ event.image or '/assets/placeholder-event.svg' }}')"></div>
              <div class="event-compact-copy">
                <div class="event-compact-topline">
                  <span>{% if event.scheduleLabel %}{{ event.scheduleLabel }}{% else %}{{ event.compactDateLabel }}{% if event.timeLabel %} · {{ event.timeLabel }}{% endif %}{% endif %}</span>
                </div>
                <h4 class="event-compact-title">{{ event.title }}</h4>
                <p class="event-compact-meta">{{ event.location }}</p>
                <div class="event-compact-badges">
                  <span class="compact-badge">{{ event.categoryLabel or 'Evento' }}</span>
                  {% if event.isFree %}<span class="compact-badge compact-badge-success">Gratis</span>{% endif %}
                </div>
              </div>
            </a>
            <div class="event-compact-actions">
              <button class="event-compact-action" type="button" data-save-event data-event-id="{{ event.id }}" aria-label="Guardar evento">
                <i class="fa-regular fa-bookmark"></i>
              </button>
            </div>
          </article>
          {% endfor %}
        </div>
      </section>

      {% if ongoing.length %}
      <section class="space-y-3">
        <div class="section-mobile-head">
          <h2 class="section-mobile-title">En curso</h2>
        </div>
        <div class="event-row-list">
          {% for event in ongoing %}
          <article class="event-compact event-compact-featured" data-category="{{ event.categoryLabel }}" data-free="{{ 'true' if event.isFree else 'false' }}" data-starts-at="{{ event.startsAt }}">
            <a href="{{ event.urlPath }}" class="event-compact-link">
              <div class="event-compact-image" style="background-image:url('{{ event.image or '/assets/placeholder-event.svg' }}')"></div>
              <div class="event-compact-copy">
                <p class="event-compact-topline"><span>{% if event.endsAtDayLabel %}Hasta {{ event.endsAtDayLabel }}{% else %}{% if event.scheduleLabel %}{{ event.scheduleLabel }}{% else %}{{ event.compactDateLabel }}{% if event.timeLabel %} · {{ event.timeLabel }}{% endif %}{% endif %}{% endif %}</span></p>
                <h4 class="event-compact-title">{{ event.title }}</h4>
                <p class="event-compact-meta">{{ event.location }}</p>
                <div class="event-compact-badges">
                  <span class="compact-badge">{{ event.categoryLabel or 'Evento' }}</span>
                </div>
              </div>
            </a>
            <div class="event-compact-actions">
              <button class="event-compact-action" type="button" data-save-event data-event-id="{{ event.id }}" aria-label="Guardar evento">
                <i class="fa-regular fa-bookmark"></i>
              </button>
            </div>
          </article>
          {% endfor %}
        </div>
      </section>
      {% endif %}
    </div>
  </section>
</main>

<div class="menu-drawer" data-menu-drawer hidden>
  <button class="menu-drawer-backdrop" type="button" data-menu-close aria-label="Cerrar menú"></button>
  <aside class="menu-drawer-panel" role="dialog" aria-modal="true" aria-label="Secciones">
    <div class="menu-drawer-head">
      <div>
        <p class="menu-drawer-kicker">ALDEA PUCELA</p>
        <h2 class="menu-drawer-title">Eventos</h2>
      </div>
      <button class="menu-drawer-close" type="button" data-menu-close aria-label="Cerrar menú">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>
    <nav class="menu-drawer-nav" aria-label="Navegación">
      <a class="menu-drawer-link menu-drawer-link-active" href="/">
        <i class="menu-drawer-link-icon fa-solid fa-house" aria-hidden="true"></i>
        <span>Inicio</span>
      </a>
      <a class="menu-drawer-link" href="/guardados">
        <i class="menu-drawer-link-icon fa-regular fa-bookmark" aria-hidden="true"></i>
        <span>Mis guardados</span>
      </a>
      <a class="menu-drawer-link" href="/archivo">
        <i class="menu-drawer-link-icon fa-solid fa-box-archive" aria-hidden="true"></i>
        <span>Archivo</span>
      </a>
      <button class="menu-drawer-link" type="button" data-subscribe-open>
        <i class="menu-drawer-link-icon fa-solid fa-rss" aria-hidden="true"></i>
        <span>Suscribirse</span>
      </button>
      <a class="menu-drawer-link" href="https://aldeapucela.org" target="_blank" rel="noopener noreferrer">
        <i class="menu-drawer-link-icon fa-solid fa-people-group" aria-hidden="true"></i>
        <span>Comunidad</span>
      </a>
      <a class="menu-drawer-link" href="https://t.me/aldeapucela/244" target="_blank" rel="noopener noreferrer">
        <i class="menu-drawer-link-icon fa-brands fa-telegram" aria-hidden="true"></i>
        <span>Chat sobre eventos</span>
      </a>
    </nav>
    <button class="menu-drawer-link menu-drawer-theme-toggle" type="button" data-theme-toggle aria-label="Cambiar tema" aria-pressed="false">
      <i class="menu-drawer-link-icon fa-regular fa-moon" aria-hidden="true"></i>
      <span data-theme-toggle-label>Modo oscuro</span>
    </button>
    <p class="menu-drawer-section-title">Filtros</p>
    <div class="menu-drawer-actions">
      <button class="menu-drawer-pick" type="button" data-filter="Hoy">
        <i class="menu-drawer-pick-icon fa-regular fa-sun" aria-hidden="true"></i>
        <span>Hoy</span>
      </button>
      <button class="menu-drawer-pick" type="button" data-filter="Esta semana">
        <i class="menu-drawer-pick-icon fa-regular fa-calendar" aria-hidden="true"></i>
        <span>Esta semana</span>
      </button>
      <button class="menu-drawer-pick" type="button" data-filter="Próxima semana">
        <i class="menu-drawer-pick-icon fa-solid fa-calendar-plus" aria-hidden="true"></i>
        <span>Próxima semana</span>
      </button>
      <button class="menu-drawer-pick" type="button" data-filter="Este finde">
        <i class="menu-drawer-pick-icon fa-solid fa-umbrella-beach" aria-hidden="true"></i>
        <span>Este finde</span>
      </button>
      <button class="menu-drawer-pick" type="button" data-filter="Este mes">
        <i class="menu-drawer-pick-icon fa-regular fa-calendar-days" aria-hidden="true"></i>
        <span>Este mes</span>
      </button>
      <button class="menu-drawer-pick" type="button" data-filter="free">
        <i class="menu-drawer-pick-icon fa-solid fa-ticket" aria-hidden="true"></i>
        <span>Gratis</span>
      </button>
    </div>
  </aside>
</div>

<button class="scroll-top-btn is-hidden" type="button" data-scroll-top aria-label="Volver arriba">
  <i class="fa-solid fa-arrow-up"></i>
</button>

<button class="share-site-btn" type="button" data-share-site aria-label="Compartir Aldea Pucela Eventos">
  <i class="fa-solid fa-share-nodes" aria-hidden="true"></i>
</button>

<button class="add-event-fab" type="button" data-add-event-open aria-label="Añadir evento">
  <i class="fa-solid fa-plus" aria-hidden="true"></i>
</button>

<div class="add-event-modal" data-add-event-modal hidden>
  <button class="add-event-modal-backdrop" type="button" data-add-event-close aria-label="Cerrar diálogo"></button>
  <aside class="add-event-modal-panel" role="dialog" aria-modal="true" aria-labelledby="add-event-title">
    <div class="add-event-modal-head">
      <span class="add-event-modal-mark" aria-hidden="true">
        <i class="fa-solid fa-calendar-plus"></i>
      </span>
      <h2 class="add-event-modal-title" id="add-event-title">Añade un evento</h2>
    </div>
    <p class="add-event-modal-copy">Sigue estos pasos para publicar un evento cultural en la agenda:</p>
    <ol class="add-event-steps">
      <li><span class="add-event-step-number">1</span><span>Entra al grupo de Telegram de la comunidad.</span></li>
      <li><span class="add-event-step-number">2</span><span>Deberás hablar un poco e interactuar con los usuarios para poder enviar imágenes.</span></li>
      <li><span class="add-event-step-number">3</span><span>Envía el cartel del evento que quieras publicar al subtema de eventos culturales.</span></li>
      <li><span class="add-event-step-number">4</span><span>Los admins lo revisarán y lo publicarán lo antes posible.</span></li>
    </ol>
    <a class="add-event-modal-cta" href="https://t.me/AldeaPucela/244/10712" target="_blank" rel="noopener noreferrer">
      Entendido, ir al grupo de chat
    </a>
  </aside>
</div>

<div class="calendar-modal" data-subscribe-modal hidden>
  <button class="calendar-modal-backdrop" type="button" data-subscribe-close aria-label="Cerrar diálogo"></button>
  <aside class="calendar-modal-panel subscribe-modal-panel" role="dialog" aria-modal="true" aria-labelledby="subscribe-modal-title">
    <div class="calendar-modal-header">
      <div>
        <h2 class="calendar-modal-title" id="subscribe-modal-title">Suscribirse</h2>
        <p class="calendar-modal-copy">Copia las URL o abre tus apps favoritas para seguir los eventos y novedades.</p>
      </div>
      <button class="calendar-modal-close" type="button" data-subscribe-close aria-label="Cerrar">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>

    <section class="subscribe-section">
      <h3 class="subscribe-section-title"><i class="fa-regular fa-calendar"></i><span>Calendario</span></h3>
      <p class="subscribe-section-copy">Suscríbete al calendario completo (incluye próximos e históricos).</p>
      <div class="subscribe-url-row">
        <input class="subscribe-url-input" type="text" value="https://eventos.aldeapucela.org/calendar.ics" readonly data-copy-source="calendar" />
        <button class="calendar-modal-action calendar-modal-action-primary subscribe-copy-btn" type="button" data-copy-url="calendar">Copiar</button>
      </div>
      <div class="subscribe-links-grid">
        <a class="calendar-modal-action" href="https://calendar.google.com/calendar/u/0/r/settings/addbyurl?url=https%3A%2F%2Feventos.aldeapucela.org%2Fcalendar.ics" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-google" aria-hidden="true"></i><span>Google Calendar</span></a>
        <a class="calendar-modal-action" href="webcal://eventos.aldeapucela.org/calendar.ics"><i class="fa-brands fa-apple" aria-hidden="true"></i><span>Apple Calendar</span></a>
        <a class="calendar-modal-action" href="https://outlook.live.com/calendar/0/addcalendar?url=https%3A%2F%2Feventos.aldeapucela.org%2Fcalendar.ics&name=Aldea%20Pucela%20Eventos" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-microsoft" aria-hidden="true"></i><span>Outlook</span></a>
      </div>
    </section>

    <section class="subscribe-section">
      <h3 class="subscribe-section-title"><i class="fa-solid fa-rss"></i><span>RSS</span></h3>
      <p class="subscribe-section-copy">Recibe nuevas publicaciones en tu lector favorito.</p>
      <div class="subscribe-url-row">
        <input class="subscribe-url-input" type="text" value="https://eventos.aldeapucela.org/rss.xml" readonly data-copy-source="rss" />
        <button class="calendar-modal-action calendar-modal-action-primary subscribe-copy-btn" type="button" data-copy-url="rss">Copiar</button>
      </div>
      <div class="subscribe-links-grid">
        <a class="calendar-modal-action" href="https://feedly.com/i/subscription/feed/https%3A%2F%2Feventos.aldeapucela.org%2Frss.xml" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-feedly" aria-hidden="true"></i><span>Feedly</span></a>
        <a class="calendar-modal-action" href="https://www.inoreader.com/?add_feed=https%3A%2F%2Feventos.aldeapucela.org%2Frss.xml" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-rss" aria-hidden="true"></i><span>Inoreader</span></a>
        <a class="calendar-modal-action" href="https://theoldreader.com/feeds/subscribe?url=https%3A%2F%2Feventos.aldeapucela.org%2Frss.xml" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-rss" aria-hidden="true"></i><span>The Old Reader</span></a>
      </div>
    </section>
  </aside>
</div>

<div class="calendar-modal" data-type-modal hidden>
  <button class="calendar-modal-backdrop" type="button" data-type-modal-close aria-label="Cerrar diálogo"></button>
  <aside class="calendar-modal-panel subscribe-modal-panel" role="dialog" aria-modal="true" aria-labelledby="type-modal-title">
    <div class="calendar-modal-header">
      <div>
        <h2 class="calendar-modal-title" id="type-modal-title">Tipos de evento</h2>
        <p class="calendar-modal-copy">Selecciona los tipos de eventos que deseas ver.</p>
      </div>
      <button class="calendar-modal-close" type="button" data-type-modal-close aria-label="Cerrar">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>

    <div class="type-modal-actions" style="display: flex; gap: 0.5rem; padding: 1rem 1.25rem 0.5rem;">
      <button class="calendar-modal-action" style="flex:1; justify-content:center; padding: 0.5rem; gap: 0.5rem;" type="button" data-type-select-all>
        <i class="fa-solid fa-check-double"></i>
        <span>Todos</span>
      </button>
      <button class="calendar-modal-action" style="flex:1; justify-content:center; padding: 0.5rem; gap: 0.5rem;" type="button" data-type-deselect-all>
        <i class="fa-solid fa-xmark"></i>
        <span>Ninguno</span>
      </button>
    </div>

    <section class="subscribe-section" style="margin-top: 0; border-top: 0; max-height: 45vh; overflow-y: auto; padding-bottom: 1rem;">
      <div class="type-checkbox-list" style="display: flex; flex-direction: column; gap: 0.25rem;">
        {% for category in categories %}
        <div class="type-checkbox-row" style="display: flex; align-items: center; justify-content: space-between; padding: 0.25rem 1.25rem;">
          <label class="type-checkbox-item" style="display: flex; align-items: center; gap: 0.75rem; flex: 1; cursor: pointer; padding: 0.25rem 0;">
            <input type="checkbox" name="type" value="{{ category }}" data-type-checkbox checked style="width: 1.25rem; height: 1.25rem; accent-color: var(--brand-500, #6f3bb2);">
            <span class="type-checkbox-label" style="font-size: 1rem;">{{ category }}</span>
          </label>
          <button class="type-only-btn" type="button" data-type-only="{{ category }}" style="font-size: 0.75rem; font-weight: 600; color: var(--brand-600, #6f3bb2); background: rgba(111, 59, 178, 0.08); border: 0; border-radius: 999px; padding: 0.25rem 0.75rem;">Solo</button>
        </div>
        {% endfor %}
      </div>
    </section>

    <div class="type-modal-footer" style="padding: 1rem 1.25rem; border-top: 1px solid rgba(0,0,0,0.05); position: sticky; bottom: 0; background: inherit; border-bottom-left-radius: inherit; border-bottom-right-radius: inherit;">
      <button class="calendar-modal-action calendar-modal-action-primary" style="width: 100%; justify-content: center; padding: 0.875rem; font-weight: 700;" type="button" data-type-modal-close>Ver resultados</button>
    </div>
  </aside>
</div>
{% endblock %}
