{% extends "layout.njk" %}

{% block header %}
<header class="topbar">
  <div class="topbar-inner">
    <a class="header-brand home-brand-mobile flex items-center gap-4" href="/" aria-label="Aldea Pucela Eventos">
      <img src="https://aldeapucela.org/img/logo-web.jpg" alt="" class="home-brand-mobile-mark" />
      <span class="home-brand-mobile-copy">
        <span class="home-brand-mobile-kicker">ALDEA PUCELA</span>
        <span class="home-brand-mobile-title">Eventos</span>
      </span>
    </a>
    <nav class="header-main-nav hidden lg:flex" aria-label="Navegación principal">
      <a class="nav-link " href="/">
        <i class="fa-solid fa-house" aria-hidden="true"></i>
        <span>Inicio</span>
      </a>
      <a class="nav-link " href="/guardados">
        <i class="fa-regular fa-bookmark" aria-hidden="true"></i>
        <span>Mis guardados</span>
      </a>
      <a class="nav-link nav-link-active" href="/archivo">
        <i class="fa-solid fa-box-archive" aria-hidden="true"></i>
        <span>Archivo</span>
      </a>
      <button class="nav-link" type="button" data-subscribe-open>
        <i class="fa-solid fa-rss" aria-hidden="true"></i>
        <span>Suscribirse</span>
      </button>
      <a class="nav-link" href="https://aldeapucela.org" target="_blank" rel="noopener noreferrer">
        <i class="fa-solid fa-people-group" aria-hidden="true"></i>
        <span>Comunidad</span>
      </a>
      <a class="nav-link" href="https://t.me/aldeapucela/244" target="_blank" rel="noopener noreferrer">
        <i class="fa-brands fa-telegram" aria-hidden="true"></i>
        <span>Chat</span>
      </a>
      <button class="nav-link nav-theme-toggle" type="button" data-theme-toggle aria-label="Cambiar tema" aria-pressed="false">
        <i class="fa-regular fa-moon" aria-hidden="true"></i>
        <span data-theme-toggle-label>Modo oscuro</span>
      </button>
    </nav>
    <button class="header-search-btn inline-flex h-11 w-11 items-center justify-center rounded-full text-slate-500 lg:hidden" type="button" data-menu-open aria-label="Abrir menú">
      <i class="fa-solid fa-bars"></i>
    </button>
  </div>
</header>
{% endblock %}

{% block body %}
<main class="page-shell py-5 sm:py-8 lg:py-10">
  <section class="home-layout space-y-7 lg:space-y-9">
    <div class="section-mobile-head">
      <h1 class="section-mobile-title">Archivo</h1>
    </div>

    {% if groups.length == 0 %}
    <div class="saved-empty" data-saved-empty>
      <div class="saved-empty-icon" aria-hidden="true">
        <i class="fa-solid fa-box-archive"></i>
      </div>
      <p class="saved-empty-copy">El archivo está vacío</p>
      <p class="saved-empty-subcopy">Aún no hay eventos pasados registrados.</p>
    </div>
    {% else %}
    <div class="week-groups">
      {% for group in groups %}
      <section class="week-day-group">
        <div class="week-day-header">
          <div class="week-day-label">{{ group.label }}</div>
        </div>
        <div class="event-row-list">
          {% for event in group.events %}
          <article class="event-compact" data-category="{{ event.categoryLabel }}" data-free="{{ 'true' if event.isFree else 'false' }}" data-starts-at="{{ event.startsAt }}">
            <a href="{{ event.urlPath }}" class="event-compact-link">
              <div class="event-compact-image" style="background-image:url('{{ event.image or '/assets/placeholder-event.svg' }}')"></div>
              <div class="event-compact-copy">
                <div class="event-compact-topline">
                  <span>{% if event.scheduleLabel %}{{ event.scheduleLabel }}{% else %}{{ event.compactDateLabel }}{% if event.timeLabel %} · {{ event.timeLabel }}{% endif %}{% endif %}</span>
                </div>
                <h4 class="event-compact-title">{{ event.title }}</h4>
                <p class="event-compact-meta">{{ event.location }}</p>
                <div class="event-compact-badges">
                  <span class="compact-badge">{{ event.categoryLabel or 'Evento' }}</span>
                  {% if event.isFree %}<span class="compact-badge compact-badge-success">Gratis</span>{% endif %}
                </div>
              </div>
            </a>
            <div class="event-compact-actions">
              <button class="event-compact-action" type="button" data-save-event data-event-id="{{ event.id }}" aria-label="Guardar evento">
                <i class="fa-regular fa-bookmark"></i>
              </button>
            </div>
          </article>
          {% endfor %}
        </div>
      </section>
      {% endfor %}
    </div>
    {% endif %}
  </section>
</main>

<button class="scroll-top-btn is-hidden" type="button" data-scroll-top aria-label="Volver arriba">
  <i class="fa-solid fa-arrow-up"></i>
</button>

<div class="menu-drawer" data-menu-drawer hidden>
  <button class="menu-drawer-backdrop" type="button" data-menu-close aria-label="Cerrar menú"></button>
  <aside class="menu-drawer-panel" role="dialog" aria-modal="true" aria-label="Secciones">
    <div class="menu-drawer-head">
      <div>
        <p class="menu-drawer-kicker">ALDEA PUCELA</p>
        <h2 class="menu-drawer-title">Eventos</h2>
      </div>
      <button class="menu-drawer-close" type="button" data-menu-close aria-label="Cerrar menú">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>
    <nav class="menu-drawer-nav" aria-label="Navegación">
      <a class="menu-drawer-link" href="/">
        <i class="menu-drawer-link-icon fa-solid fa-house" aria-hidden="true"></i>
        <span>Inicio</span>
      </a>
      <a class="menu-drawer-link" href="/guardados">
        <i class="menu-drawer-link-icon fa-regular fa-bookmark" aria-hidden="true"></i>
        <span>Mis guardados</span>
      </a>
      <a class="menu-drawer-link menu-drawer-link-active" href="/archivo">
        <i class="menu-drawer-link-icon fa-solid fa-box-archive" aria-hidden="true"></i>
        <span>Archivo</span>
      </a>
      <button class="menu-drawer-link" type="button" data-subscribe-open>
        <i class="menu-drawer-link-icon fa-solid fa-rss" aria-hidden="true"></i>
        <span>Suscribirse</span>
      </button>
      <a class="menu-drawer-link" href="https://aldeapucela.org" target="_blank" rel="noopener noreferrer">
        <i class="menu-drawer-link-icon fa-solid fa-people-group" aria-hidden="true"></i>
        <span>Comunidad</span>
      </a>
      <a class="menu-drawer-link" href="https://t.me/aldeapucela/244" target="_blank" rel="noopener noreferrer">
        <i class="menu-drawer-link-icon fa-brands fa-telegram" aria-hidden="true"></i>
        <span>Chat sobre eventos</span>
      </a>
    </nav>
    <button class="menu-drawer-link menu-drawer-theme-toggle" type="button" data-theme-toggle aria-label="Cambiar tema" aria-pressed="false">
      <i class="menu-drawer-link-icon fa-regular fa-moon" aria-hidden="true"></i>
      <span data-theme-toggle-label>Modo oscuro</span>
    </button>
  </aside>
</div>

<div class="calendar-modal" data-subscribe-modal hidden>
  <button class="calendar-modal-backdrop" type="button" data-subscribe-close aria-label="Cerrar diálogo"></button>
  <aside class="calendar-modal-panel subscribe-modal-panel" role="dialog" aria-modal="true" aria-labelledby="subscribe-modal-title">
    <div class="calendar-modal-header">
      <div>
        <h2 class="calendar-modal-title" id="subscribe-modal-title">Suscribirse</h2>
        <p class="calendar-modal-copy">Copia las URL o abre tus apps favoritas para seguir los eventos y novedades.</p>
      </div>
      <button class="calendar-modal-close" type="button" data-subscribe-close aria-label="Cerrar">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>

    <section class="subscribe-section">
      <h3 class="subscribe-section-title"><i class="fa-regular fa-calendar"></i><span>Calendario</span></h3>
      <p class="subscribe-section-copy">Suscríbete al calendario completo (incluye próximos e históricos).</p>
      <div class="subscribe-url-row">
        <input class="subscribe-url-input" type="text" value="https://eventos.aldeapucela.org/calendar.ics" readonly data-copy-source="calendar" />
        <button class="calendar-modal-action calendar-modal-action-primary subscribe-copy-btn" type="button" data-copy-url="calendar">Copiar</button>
      </div>
      <div class="subscribe-links-grid">
        <a class="calendar-modal-action" href="https://calendar.google.com/calendar/u/0/r/settings/addbyurl?url=https%3A%2F%2Feventos.aldeapucela.org%2Fcalendar.ics" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-google" aria-hidden="true"></i><span>Google Calendar</span></a>
        <a class="calendar-modal-action" href="webcal://eventos.aldeapucela.org/calendar.ics"><i class="fa-brands fa-apple" aria-hidden="true"></i><span>Apple Calendar</span></a>
        <a class="calendar-modal-action" href="https://outlook.live.com/calendar/0/addcalendar?url=https%3A%2F%2Feventos.aldeapucela.org%2Fcalendar.ics&name=Aldea%20Pucela%20Eventos" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-microsoft" aria-hidden="true"></i><span>Outlook</span></a>
      </div>
    </section>

    <section class="subscribe-section">
      <h3 class="subscribe-section-title"><i class="fa-solid fa-rss"></i><span>RSS</span></h3>
      <p class="subscribe-section-copy">Recibe nuevas publicaciones en tu lector favorito.</p>
      <div class="subscribe-url-row">
        <input class="subscribe-url-input" type="text" value="https://eventos.aldeapucela.org/rss.xml" readonly data-copy-source="rss" />
        <button class="calendar-modal-action calendar-modal-action-primary subscribe-copy-btn" type="button" data-copy-url="rss">Copiar</button>
      </div>
      <div class="subscribe-links-grid">
        <a class="calendar-modal-action" href="https://feedly.com/i/subscription/feed/https%3A%2F%2Feventos.aldeapucela.org%2Frss.xml" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-feedly" aria-hidden="true"></i><span>Feedly</span></a>
        <a class="calendar-modal-action" href="https://www.inoreader.com/?add_feed=https%3A%2F%2Feventos.aldeapucela.org%2Frss.xml" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-rss" aria-hidden="true"></i><span>Inoreader</span></a>
        <a class="calendar-modal-action" href="https://theoldreader.com/feeds/subscribe?url=https%3A%2F%2Feventos.aldeapucela.org%2Frss.xml" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-rss" aria-hidden="true"></i><span>The Old Reader</span></a>
      </div>
    </section>
  </aside>
</div>
{% endblock %}
