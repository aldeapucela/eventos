{# Espejo del markup de renderWeekItem() en src/scripts/home.js: si cambias
   este partial, cambia también esa función (y viceversa). #}
<article class="event-compact" data-category="{{ event.categoryLabel or '' }}" data-free="{{ 'true' if event.isFree else 'false' }}" data-venue="{{ event.venueLabel or event.location or '' }}" data-venue-key="{{ event.venueKey or '' }}" data-starts-at="{{ event.startsAt or '' }}" data-ends-at="{{ event.endsAt or '' }}">
  <a href="{{ event.urlPath }}" class="event-compact-link">
    <div class="event-compact-image" style="background-image:url('{{ event.image or '/assets/placeholder-event.svg' }}')"></div>
    <div class="event-compact-copy">
    <div class="event-compact-topline">
      <span>{% if cardWithYear and event.detailScheduleLabel %}{{ event.detailScheduleLabel }}{% elif event.scheduleLabel %}{{ event.scheduleLabel }}{% else %}{{ event.compactDateLabel or '' }}{% if event.timeLabel %} · {{ event.timeLabel }}{% endif %}{% endif %}</span>
    </div>
    <h4 class="event-compact-title">{{ event.title or '' }}</h4>
    <p class="event-compact-meta">{{ event.location or '' }}</p>
    <div class="event-compact-badges">
      <span class="compact-badge">{{ event.categoryLabel or 'Evento' }}</span>
      {% if event.isFree %}<span class="compact-badge compact-badge-success">Gratis</span>{% endif %}
    </div>
    </div>
  </a>
  <div class="event-compact-actions">
    <button class="event-compact-action" type="button" data-save-event data-event-id="{{ event.id }}" aria-label="Guardar evento">
      <i class="fa-regular fa-bookmark"></i>
    </button>
  </div>
</article>
