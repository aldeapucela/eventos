{# Los chips temporales son enlaces a páginas estáticas (/hoy/, /fin-de-semana/...);
   el chip activo enlaza a / para "quitar" el filtro. #}
<div class="mobile-chip-row" aria-label="Filtros rápidos">
  <a class="mobile-chip{% if timeFilterKey == 'Hoy' %} mobile-chip-active{% endif %}" href="{% if timeFilterKey == 'Hoy' %}/{% else %}/hoy/{% endif %}"{% if timeFilterKey == 'Hoy' %} aria-current="page"{% endif %}>
    <i class="mobile-chip-icon fa-regular fa-sun" aria-hidden="true"></i>
    <span>Hoy</span>
  </a>
  <a class="mobile-chip{% if timeFilterKey == 'Este finde' %} mobile-chip-active{% endif %}" href="{% if timeFilterKey == 'Este finde' %}/{% else %}/fin-de-semana/{% endif %}"{% if timeFilterKey == 'Este finde' %} aria-current="page"{% endif %}>
    <i class="mobile-chip-icon fa-solid fa-umbrella-beach" aria-hidden="true"></i>
    <span>Este finde</span>
  </a>
  <a class="mobile-chip{% if timeFilterKey == 'Esta semana' %} mobile-chip-active{% endif %}" href="{% if timeFilterKey == 'Esta semana' %}/{% else %}/esta-semana/{% endif %}"{% if timeFilterKey == 'Esta semana' %} aria-current="page"{% endif %}>
    <i class="mobile-chip-icon fa-regular fa-calendar" aria-hidden="true"></i>
    <span>Esta semana</span>
  </a>
  <a class="mobile-chip{% if timeFilterKey == 'Próxima semana' %} mobile-chip-active{% endif %}" href="{% if timeFilterKey == 'Próxima semana' %}/{% else %}/proxima-semana/{% endif %}"{% if timeFilterKey == 'Próxima semana' %} aria-current="page"{% endif %}>
    <i class="mobile-chip-icon fa-solid fa-calendar-plus" aria-hidden="true"></i>
    <span>Próxima semana</span>
  </a>
  <button class="mobile-chip mobile-chip-select-wrap mobile-chip-date-trigger{% if timeFilterKey == 'Este mes' or timeFilterKey == 'Próximos 3 meses' %} mobile-chip-active{% endif %}" type="button" data-date-modal-open aria-label="Filtrar por fecha">
    <i class="mobile-chip-icon mobile-chip-leading fa-regular fa-calendar-days" aria-hidden="true"></i>
    <span data-filter-date-label>{% if timeFilterKey == 'Este mes' or timeFilterKey == 'Próximos 3 meses' %}Fecha · {{ timeFilterKey }}{% else %}Fecha{% endif %}</span>
  </button>
  <button class="mobile-chip" data-filter="free">
    <i class="mobile-chip-icon fa-solid fa-ticket" aria-hidden="true"></i>
    <span>Gratis</span>
  </button>
  <button class="mobile-chip mobile-chip-select-wrap mobile-chip-type-trigger" type="button" data-type-modal-open aria-label="Filtrar por tipo">
    <i class="mobile-chip-icon mobile-chip-leading fa-solid fa-filter" aria-hidden="true"></i>
    <span data-filter-type-label>Tipo</span>
  </button>
  <button class="mobile-chip mobile-chip-select-wrap mobile-chip-venue-trigger" type="button" data-venue-modal-open aria-label="Filtrar por espacio">
    <i class="mobile-chip-icon mobile-chip-leading fa-solid fa-location-dot" aria-hidden="true"></i>
    <span data-filter-venue-label>Espacio</span>
  </button>
</div>
