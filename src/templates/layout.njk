<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="{{ meta.description or 'Agenda cultural de Aldea Pucela' }}" />
    <title>{{ title or 'Aldea Pucela Eventos' }}</title>
    <link rel="icon" type="image/png" href="/assets/favicon.png" />
    <link rel="alternate" type="application/rss+xml" title="Aldea Pucela Eventos RSS" href="https://eventos.aldeapucela.org/rss.xml" />
    <link rel="alternate" type="text/calendar" title="Aldea Pucela Eventos Calendario" href="https://eventos.aldeapucela.org/calendar.ics" />
    {% if social %}
    <meta property="og:type" content="{{ social.type or 'website' }}" />
    <meta property="og:title" content="{{ social.title or title or 'Aldea Pucela Eventos' }}" />
    <meta property="og:description" content="{{ social.description or meta.description or 'Agenda cultural de Aldea Pucela' }}" />
    {% if social.image %}<meta property="og:image" content="{{ social.image }}" />{% endif %}
    {% if social.url %}<meta property="og:url" content="{{ social.url }}" />{% endif %}
    <meta name="twitter:card" content="{{ social.card or 'summary_large_image' }}" />
    <meta name="twitter:title" content="{{ social.title or title or 'Aldea Pucela Eventos' }}" />
    <meta name="twitter:description" content="{{ social.description or meta.description or 'Agenda cultural de Aldea Pucela' }}" />
    {% if social.image %}<meta name="twitter:image" content="{{ social.image }}" />{% endif %}
    {% endif %}
    <script>
      (function () {
        const key = 'aldeapucela_theme';
        try {
          const saved = window.localStorage.getItem(key);
          const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
          const theme = saved === 'dark' || saved === 'light' ? saved : (prefersDark ? 'dark' : 'light');
          if (theme === 'dark') {
            document.documentElement.classList.add('dark');
          }
          document.documentElement.style.colorScheme = theme;
        } catch (_) {}
      }());
    </script>
    <link rel="stylesheet" href="/assets/css/{{ pageCss }}?v={{ assetVersion }}" />
    <link rel="stylesheet" href="/assets/fontawesome/css/all.min.css" />
  </head>
  <body>
    {% block header %}{% endblock %}
    {% block body %}{% endblock %}
    <div class="saved-toast" data-saved-toast aria-live="polite" aria-atomic="true" hidden>
      <p class="saved-toast-copy">
        <span data-saved-toast-prefix></span>&nbsp;
        <a class="saved-toast-link" href="/guardados"> lista de guardados</a>
      </p>
    </div>
    <script>
      window.__EVENTS__ = {{ eventsJson | safe }};
      window.__FILTERS__ = {{ filtersJson | safe }};
      (function () {
        const toast = document.querySelector('[data-saved-toast]');
        if (!toast) return;
        const prefix = toast.querySelector('[data-saved-toast-prefix]');
        const link = toast.querySelector('.saved-toast-link');
        let hideTimer = null;
        const copy = {
          added: 'Evento añadido a tu ',
          removed: 'Evento eliminado de tu '
        };

        window.showSavedToast = function showSavedToast(options) {
          const action = options && options.action === 'removed' ? 'removed' : 'added';
          if (prefix) {
            prefix.textContent = copy[action];
          }
          toast.hidden = false;
          toast.classList.add('saved-toast-visible');
          window.clearTimeout(hideTimer);
          hideTimer = window.setTimeout(() => {
            toast.classList.remove('saved-toast-visible');
            window.setTimeout(() => {
              if (!toast.classList.contains('saved-toast-visible')) {
                toast.hidden = true;
              }
            }, 180);
          }, 2000);
        };

        if (link) {
          link.addEventListener('click', () => {
            window.clearTimeout(hideTimer);
          });
        }
      }());
    </script>
    <script src="/assets/js/matomo.js?v={{ assetVersion }}"></script>
    <script type="module" src="/assets/js/{{ pageJs }}?v={{ assetVersion }}" defer></script>
  </body>
</html>
