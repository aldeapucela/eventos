{% extends "layout.njk" %}

{% block extraHead %}
<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
  crossorigin=""
/>
{% endblock %}

{% block header %}
<header class="topbar">
  <div class="topbar-inner">
    <a class="header-brand home-brand-mobile flex items-center gap-4" href="/" aria-label="Aldea Pucela Eventos">
      <img src="https://aldeapucela.org/img/logo-web.jpg" alt="" class="home-brand-mobile-mark" />
      <span class="home-brand-mobile-copy">
        <span class="home-brand-mobile-kicker">ALDEA PUCELA</span>
        <span class="home-brand-mobile-title">Eventos</span>
      </span>
    </a>
    <nav class="header-main-nav hidden lg:flex" aria-label="Navegación principal">
      <a class="nav-link " href="/">
        <i class="fa-solid fa-house" aria-hidden="true"></i>
        <span>Inicio</span>
      </a>
      <a class="nav-link nav-link-active" href="/espacios">
        <i class="fa-solid fa-location-dot" aria-hidden="true"></i>
        <span>Espacios</span>
      </a>
      <a class="nav-link " href="/guardados">
        <i class="fa-regular fa-bookmark" aria-hidden="true"></i>
        <span>Mis guardados</span>
      </a>
      <a class="nav-link " href="/archivo">
        <i class="fa-solid fa-box-archive" aria-hidden="true"></i>
        <span>Archivo</span>
      </a>
      <button class="nav-link" type="button" data-subscribe-open>
        <i class="fa-solid fa-rss" aria-hidden="true"></i>
        <span>Suscribirse</span>
      </button>
      <a class="nav-link" href="https://aldeapucela.org" target="_blank" rel="noopener noreferrer">
        <i class="fa-solid fa-people-group" aria-hidden="true"></i>
        <span>Comunidad</span>
      </a>
      <a class="nav-link" href="https://t.me/aldeapucela/244" target="_blank" rel="noopener noreferrer">
        <i class="fa-brands fa-telegram" aria-hidden="true"></i>
        <span>Chat</span>
      </a>
      <button class="nav-link nav-theme-toggle" type="button" data-theme-toggle aria-label="Cambiar tema" aria-pressed="false">
        <i class="fa-regular fa-moon" aria-hidden="true"></i>
        <span data-theme-toggle-label>Modo oscuro</span>
      </button>
    </nav>
    <button class="header-search-btn inline-flex h-11 w-11 items-center justify-center rounded-full text-slate-500 lg:hidden" type="button" data-menu-open aria-label="Abrir menú">
      <i class="fa-solid fa-bars"></i>
    </button>
  </div>
</header>
{% endblock %}

{% block body %}
<main class="page-shell py-5 sm:py-8 lg:py-10">
  <section class="home-layout space-y-7 lg:space-y-9">
    <section class="spaces-hero-copy">
      <h1 class="spaces-page-title">Espacios</h1>
      <p class="spaces-hero-text">Eventos próximos y en curso durante los próximos seis meses agrupados por espacio</p>
    </section>

    <div class="spaces-hero-stats" aria-label="Resumen de espacios">
      <article class="spaces-stat-card">
        <span class="spaces-stat-value">{{ spacesCount }}</span>
        <span class="spaces-stat-label">espacios con actividad</span>
      </article>
      <article class="spaces-stat-card">
        <span class="spaces-stat-value">{{ futureEventsCount }}</span>
        <span class="spaces-stat-label">eventos vigentes</span>
      </article>
    </div>

    {% if spaces.length == 0 %}
    <div class="saved-empty">
      <div class="saved-empty-icon" aria-hidden="true">
        <i class="fa-solid fa-location-dot"></i>
      </div>
      <p class="saved-empty-copy">No hay espacios con eventos vigentes</p>
      <p class="saved-empty-subcopy">Cuando entren nuevos eventos próximos o en curso en los próximos seis meses con venue detectado, aparecerán aquí agrupados.</p>
    </div>
    {% else %}
    <div class="spaces-map-frame">
      <div class="spaces-map-canvas" data-spaces-map></div>
    </div>

    <div class="spaces-groups">
      {% for space in spaces %}
      <section class="spaces-card" id="{{ space.slug }}">
        <div class="spaces-card-head">
          <div class="spaces-card-copy">
            <h2 class="spaces-card-title">{% if space.pageHref %}<a href="{{ space.pageHref }}">{{ space.name }}</a>{% else %}{{ space.name }}{% endif %}</h2>
            <div class="spaces-card-meta">
              <span><i class="fa-regular fa-calendar" aria-hidden="true"></i>{{ space.count }} {% if space.count == 1 %}evento{% else %}eventos{% endif %}</span>
              {% if space.address or space.name %}
              <a class="spaces-card-location" data-location-open data-location="{{ space.address or space.name }}" href="#">
                <i class="fa-solid fa-location-dot" aria-hidden="true"></i><span class="spaces-card-location-text">{{ space.address or space.name }}</span>
              </a>
              {% endif %}
            </div>
          </div>
          <div class="spaces-card-next">
            <i class="fa-regular fa-clock" aria-hidden="true"></i>
            <span class="spaces-card-next-value">Siguiente: {{ (space.events[0].scheduleLabel or space.events[0].dateRangeLabel) | upper }}</span>
          </div>
        </div>

        <div class="event-row-list">
          {% for event in space.events %}
          <article class="event-compact" data-category="{{ event.categoryLabel }}" data-free="{{ 'true' if event.isFree else 'false' }}" data-starts-at="{{ event.startsAt }}">
            <a href="{{ event.urlPath }}" class="event-compact-link">
              <div class="event-compact-image" style="background-image:url('{{ event.image or '/assets/placeholder-event.svg' }}')"></div>
              <div class="event-compact-copy">
                <div class="event-compact-topline">
                  <span>{% if event.scheduleLabel %}{{ event.scheduleLabel }}{% else %}{{ event.compactDateLabel }}{% if event.timeLabel %} · {{ event.timeLabel }}{% endif %}{% endif %}</span>
                </div>
                <h4 class="event-compact-title">{{ event.title }}</h4>
                <p class="event-compact-meta">
                  {% if event.location and event.location != space.name %}{{ event.location }}{% elseif event.address %}{{ event.address }}{% else %}{{ event.location }}{% endif %}
                </p>
                <div class="event-compact-badges">
                  <span class="compact-badge">{{ event.categoryLabel or 'Evento' }}</span>
                  {% if event.isFree %}<span class="compact-badge compact-badge-success">Gratis</span>{% endif %}
                </div>
              </div>
            </a>
            <div class="event-compact-actions">
              <button class="event-compact-action" type="button" data-save-event data-event-id="{{ event.id }}" aria-label="Guardar evento">
                <i class="fa-regular fa-bookmark"></i>
              </button>
            </div>
          </article>
          {% endfor %}
        </div>
      </section>
      {% endfor %}
    </div>
    {% endif %}
  </section>
</main>

<button class="scroll-top-btn is-hidden" type="button" data-scroll-top aria-label="Volver arriba">
  <i class="fa-solid fa-arrow-up"></i>
</button>

<div class="menu-drawer" data-menu-drawer hidden>
  <button class="menu-drawer-backdrop" type="button" data-menu-close aria-label="Cerrar menú"></button>
  <aside class="menu-drawer-panel" role="dialog" aria-modal="true" aria-label="Secciones">
    <div class="menu-drawer-head">
      <div>
        <p class="menu-drawer-kicker">ALDEA PUCELA</p>
        <h2 class="menu-drawer-title">Eventos</h2>
      </div>
      <button class="menu-drawer-close" type="button" data-menu-close aria-label="Cerrar menú">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>
    <nav class="menu-drawer-nav" aria-label="Navegación">
      <a class="menu-drawer-link" href="/">
        <i class="menu-drawer-link-icon fa-solid fa-house" aria-hidden="true"></i>
        <span>Inicio</span>
      </a>
      <a class="menu-drawer-link menu-drawer-link-active" href="/espacios">
        <i class="menu-drawer-link-icon fa-solid fa-location-dot" aria-hidden="true"></i>
        <span>Espacios</span>
      </a>
      <a class="menu-drawer-link" href="/guardados">
        <i class="menu-drawer-link-icon fa-regular fa-bookmark" aria-hidden="true"></i>
        <span>Mis guardados</span>
      </a>
      <a class="menu-drawer-link" href="/archivo">
        <i class="menu-drawer-link-icon fa-solid fa-box-archive" aria-hidden="true"></i>
        <span>Archivo</span>
      </a>
      <button class="menu-drawer-link" type="button" data-subscribe-open>
        <i class="menu-drawer-link-icon fa-solid fa-rss" aria-hidden="true"></i>
        <span>Suscribirse</span>
      </button>
      <a class="menu-drawer-link" href="https://aldeapucela.org" target="_blank" rel="noopener noreferrer">
        <i class="menu-drawer-link-icon fa-solid fa-people-group" aria-hidden="true"></i>
        <span>Comunidad</span>
      </a>
      <a class="menu-drawer-link" href="https://t.me/aldeapucela/244" target="_blank" rel="noopener noreferrer">
        <i class="menu-drawer-link-icon fa-brands fa-telegram" aria-hidden="true"></i>
        <span>Chat sobre eventos</span>
      </a>
    </nav>
    <button class="menu-drawer-link menu-drawer-theme-toggle" type="button" data-theme-toggle aria-label="Cambiar tema" aria-pressed="false">
      <i class="menu-drawer-link-icon fa-regular fa-moon" aria-hidden="true"></i>
      <span data-theme-toggle-label>Modo oscuro</span>
    </button>
  </aside>
</div>

{% include "partials/subscribe-modal.njk" %}

<div class="location-modal" data-location-modal hidden>
  <button class="location-modal-backdrop" type="button" data-location-close aria-label="Cerrar"></button>
  <div class="location-modal-panel" role="dialog" aria-modal="true" aria-labelledby="location-modal-title">
    <div class="location-modal-header">
      <h2 class="location-modal-title" id="location-modal-title">Abrir ubicación en</h2>
      <button class="location-modal-close" type="button" data-location-close aria-label="Cerrar">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>
    <div class="location-modal-actions">
      <a class="location-modal-action" data-location-map="openstreetmap" href="#" target="_blank" rel="noreferrer">
        <i class="fa-solid fa-map-location-dot"></i>
        <span>OpenStreetMap</span>
      </a>
      <a class="location-modal-action" data-location-map="google" href="#" target="_blank" rel="noreferrer">
        <i class="fa-brands fa-google"></i>
        <span>Google Maps</span>
      </a>
      <a class="location-modal-action" data-location-map="apple" href="#" target="_blank" rel="noreferrer">
        <i class="fa-brands fa-apple"></i>
        <span>Apple Maps</span>
      </a>
      <a class="location-modal-action" data-location-map="bing" href="#" target="_blank" rel="noreferrer">
        <i class="fa-brands fa-microsoft"></i>
        <span>Bing Maps</span>
      </a>
    </div>
  </div>
</div>

<script>
  window.__SPACES__ = {{ spacesDataJson | safe }};
</script>
{% endblock %}

{% block extraScripts %}
<script
  src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
  integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
  crossorigin=""
></script>
<script type="module" src="/assets/js/spaces.js?v={{ assetVersion }}"></script>
{% endblock %}
